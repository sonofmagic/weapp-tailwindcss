    list-style-type: upper-alpha;
  }
  .blockquote .p:first-of-type::before {
    content: open-quote;
  }
  .blockquote .p:last-of-type::after {
    content: close-quote;
  }
  .h4 .strong {
    font-weight: 700;
  }
  .figure > * {
    margin: 0;
  }
  .ol > .li::marker {
    font-weight: 400;
    color: var(--tw-prose-counters);
  }
  .code::before {
    content: "&#96;";
  }
  .code::after {
    content: "&#96;";
  }
}
.prose-headings\\:text-ellipsis {
  & .h1 {
    text-overflow: ellipsis;
  }
  & .h2 {
    text-overflow: ellipsis;
  }
  & .h3 {
    text-overflow: ellipsis;
  }
  & .h4 {
    text-overflow: ellipsis;
  }
  & .h5 {
    text-overflow: ellipsis;
  }
  & .h6 {
    text-overflow: ellipsis;
  }
  & .th {
    text-overflow: ellipsis;
  }
}
.prose-h1\\:text-center {
  & .h1 {
    text-align: center;
  }
}"
`;

exports[`lifts all common, trailing pseudo elements when the same across all selectors 1`] = `
"*,:after,:before,::backdrop {
  box-sizing: border-box;
  border: 0 solid;
  margin: 0;
  padding: 0;
}
.prose {
  .ol .li::marker::before, .ul .li::marker::before {
    color: red;
  }
}
.dark\\:prose {
  &:is(.dark *) {
    .ol .li::marker::before, .ul .li::marker::before {
      color: red;
    }
  }
}"
`;


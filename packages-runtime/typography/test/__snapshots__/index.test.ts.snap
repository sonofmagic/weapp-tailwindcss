exports[`custom class name 1`] = `
"*,:after,:before,::backdrop {
  box-sizing: border-box;
  border: 0 solid;
  margin: 0;
  padding: 0;
}
.markdown {
  color: var(--tw-prose-body);
  max-width: 65ch;
  [class~="lead"] {
    color: var(--tw-prose-lead);
  }
  .strong {
    color: var(--tw-prose-bold);
    font-weight: 600;
  }
  .ol[type="A"] {
    list-style-type: upper-alpha;
  }
  .blockquote .p:first-of-type::before {
    content: open-quote;
  }
  .blockquote .p:last-of-type::after {
    content: close-quote;
  }
  .h4 .strong {
    font-weight: 700;
  }
  .figure > * {
    margin: 0;
  }
  .ol > .li::marker {
    font-weight: 400;
    color: var(--tw-prose-counters);
  }
  .code::before {
    content: "&#96;";
  }
  .code::after {
    content: "&#96;";
  }
}"
`;

exports[`customizing defaults with multiple values does not result in invalid css 1`] = `
"*,:after,:before,::backdrop {
  box-sizing: border-box;
  border: 0 solid;
  margin: 0;
  padding: 0;
}
.prose {
  text-align: -webkit-match-parent;
  text-align: match-parent;
}"
`;

exports[`does not modify selectors with differing pseudo elements 1`] = `
"*,:after,:before,::backdrop {
  box-sizing: border-box;
  border: 0 solid;
  margin: 0;
  padding: 0;
}
.prose {
  .ol .li::before, .ul .li::after {
    color: red;
  }
}
.dark\\:prose {
  &:is(.dark *) {
    .ol .li::before, .ul .li::after {
      color: red;
    }
  }
}"
`;


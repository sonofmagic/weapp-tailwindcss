{
  "name": "@weapp-tailwindcss/typography",
  "type": "module",
  "version": "1.0.1",
  "description": "The tailwindcss typography plugin for weapp",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://tw.icebreaker.top/docs/community/typography",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/weapp-tailwindcss.git",
    "directory": "packages-runtime/typography"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/weapp-tailwindcss/issues"
  },
  "keywords": [
    "weapp",
    "tailwindcss",
    "typography"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "import": "./dist/transform.js",
      "require": "./dist/transform.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown && node -e \"require('node:fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\"",
    "test": "vitest run",
    "test:dev": "vitest",
    "tsd": "tsd",
    "release": "pnpm publish",
    "sync": "cnpm sync @weapp-tailwindcss/typography"
  },
  "dependencies": {
    "htmlparser2": "^12.0.0",
    "lodash.castarray": "^4.4.0",
    "lodash.isplainobject": "^4.0.6",
    "lodash.merge": "^4.6.2",
    "magic-string": "^1.0.0",
    "postcss-selector-parser": "^7.1.4"
  },
  "devDependencies": {
    "@weapp-tailwindcss/test-helper": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}

}
.nut-theme-dark .nut-ecard .nut-ecard__list__input.active > view > input {
  background: var(--nut-dark-background7, #707070);
}
.nut-theme-dark .nut-ecard .nut-ecard__list__input .nut-ecard__list__input--con > input {

{
  "name": "uni-app-x-weapp-tailwindcss-template",
  "scripts": {
    "start:android:emulator": "node ./scripts/start-android-emulator.mjs",
    "start:ios:simulator": "open -a Simulator",
    "dev:android:emulator": "uni-launch app-android --deviceId emulator-5554",
    "dev:ios:simulator": "uni-launch app-ios --iosTarget simulator",
    "up:pkg": "pnpm up -rLi \"!@dcloudio/*\""
  },
  "devDependencies": {
    "@dcloudio/hbuilderx-cli": "^1.2.0",
    "@weapp-tailwindcss/debug-uni-app-x": "1.0.1",
    "tailwindcss": "^3.4.19",
    "weapp-tailwindcss": "5.0.7"
  },
  "packageManager": "pnpm@11.5.3"
}

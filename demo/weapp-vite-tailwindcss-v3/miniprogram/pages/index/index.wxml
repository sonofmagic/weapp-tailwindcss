<view class="p-4">
  <view class="hidden min-h-screen {{ mode === 'light'?'bg-[#111111] text-slate-800':'bg-gray-900 text-slate-200' }} transition-colors duration-500"></view>
  <view class="{{className}}">className</view>
  <view class="{{ active ? 'bg-[red]' : 'text-red-500' }}">{{ message === 'Hello world!' ? 'keep-[business]' : 'at App.vue:4' }}</view>
  <view class="{{ ['text-red-500', active ? 'bg-[red]' : 'text-blue-500'].join(' ') }}">{{ ['Hello world!', 'keep-[business]', 'at App.vue:4 index.ts:120:3'].join('|') }}</view>
  <view class="{{ active ? 'bg-[red]' : (message === 'Hello world!' ? 'text-red-500' : 'text-blue-500') }}">{{ message.includes('Hello world!') ? 'before content [\"not-generated\"]' : 'https://example.com/a[b]?q=Hello world!' }}</view>
  <view data-trace="at App.vue:4 index.ts:120:3" data-expression="size > 4 ? keep-[business] : App.vue:4" data-missing="before content [&quot;not-generated&quot;]"></view>
  <view class="flex items-center gap-3 text-slate-700">
    <view class="icon-[mdi--home] size-8 text-sky-600"></view>
    <view class="icon-[mdi--account] size-8 text-emerald-600"></view>
    <view class="iconify-[lucide--settings] size-8 text-violet-600"></view>
    <view class="iconify-[lucide--bell] size-8 text-rose-600"></view>
  </view>
  <view class="theme-mode-demo mt-4 rounded bg-white px-4 py-3 text-slate-900 system-dark:bg-slate-900 system-dark:text-slate-100 theme-dark:bg-zinc-900 theme-dark:text-zinc-50 dark:bg-zinc-900 dark:text-zinc-50">
    Weapp Vite Tailwind CSS v3 system dark
    <view class="theme-dark mt-2 rounded bg-white px-3 py-2 text-slate-900 theme-dark:bg-zinc-950 theme-dark:text-zinc-50">
      Weapp Vite Tailwind CSS v3 manual dark
    </view>
  </view>
  <IceButton class="bg-[#d72929]" tw-class="bg-[orange]" hover-class="bg-[green]" tw-hover-class="bg-[pink]"></IceButton>
  <view class="dark:hover:border-green-300 dark:hover:bg-gray-600">111222</view>
</view>

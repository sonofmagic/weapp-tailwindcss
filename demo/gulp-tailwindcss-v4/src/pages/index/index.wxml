<!-- index.wxml -->
<view class="h-full text-center">
  <view class="m-[20px]">
    <view class="bg-[url(https://pic1.zhimg.com/v2-3ee20468f54bbfefcd0027283b21aaa8_720w.jpg)] bg-[length:100%_100%] bg-no-repeat w-screen h-[41.54vw]"></view>
    <view class="space-y-4">
      <view wx:if="{{motto}}" class="text-[14px]">基于Gulp 的微信小程序前端开发工作流</view>
      <view class="text-[14px] text-[#5ba4e5]" wx:if="{{motto}}" bindtap="copyText" data-text="https://github.com/sonofmagic/weapp-tailwindcss">
        https://github.com/sonofmagic/weapp-tailwindcss
      </view>
      <view class="text-xs font-medium">Fork from Jeff2Ma/WeApp-Workflow</view>
      <view>{{wildContent}}</view>
    </view>
    <view class="theme-mode-demo mt-4 rounded bg-white px-4 py-3 text-left text-slate-900 system-dark:bg-slate-900 system-dark:text-slate-100 dark:bg-zinc-900 dark:text-zinc-50">
      Gulp Tailwind CSS v4 system dark
      <view class="theme-dark mt-2 rounded bg-white px-3 py-2 text-slate-900 dark:bg-zinc-950 dark:text-zinc-50">
        Gulp Tailwind CSS v4 manual dark
      </view>
    </view>
    <t-button t-class="bg-[#0977ee] text-[31rpx]" t-class-content="px-[29rpx]">issue 977 t-class</t-button>
    <view class="{{contentStyle}}">
      <view class="text-base font-bold pb-[10px] mb-[20px] text-left border-b border-[#EEEEEE]">
        功能介绍
      </view>
      <view class="pl-[15px] text-left block">
        <view class="text-xs">支持 tailwindcss <text class="i-[mdi--github-circle]"></text> </view>
        <view class="text-xs">SCSS 实时编译为 WXSS  <text class="i-[mdi--ab-testing]"></text></view>
        <view class="text-xs">px 和 rem 单位转小程序单位rpx <text class="i-[mdi--abacus]"></text></view>
        <view class="text-xs">支持 typescript <text class="i-[mdi--typewriter]"></text></view>
        <view wx:if="{{arr.length>0}}" class="mt-[24px] bg-[red]">mt-[24px]</view>
        <view class="mt-[33px]" wx:if="{{arr.length>0}}">mt-[33px]</view>
      </view>
      <view class="{{classNames}}"></view>
    </view>
  </view>
</view>

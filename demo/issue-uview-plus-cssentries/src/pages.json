{
  "pages": [
    {
      "path": "pages/demonstration/index",
      "style": {
        "navigationBarTitleText": "uview cssEntries"
      }
    }
  ],
  "subPackages": [
    {
      "root": "sub-normal",
      "pages": [
        {
          "path": "pages/index"
        }
      ]
    },
    {
      "root": "sub-independent",
      "pages": [
        {
          "path": "pages/index"
        }
      ],
      "independent": true
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uview cssEntries",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  }
}

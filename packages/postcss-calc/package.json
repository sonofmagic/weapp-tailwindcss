{
  "name": "@weapp-tailwindcss/postcss-calc",
  "version": "1.0.2",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "description": "PostCSS plugin to reduce calc()",
  "keywords": [
    "css",
    "postcss",
    "postcss-plugin",
    "calculation",
    "calc"
  ],
  "homepage": "https://tw.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/weapp-tailwindcss.git",
    "directory": "packages/postcss-calc"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/weapp-tailwindcss/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run build:parser && tsdown",
    "build:parser": "jison ./parser.jison -o src/parser.cjs",
    "build:types": "tsdown --dts-only",
    "lint": "eslint . && tsc --noEmit",
    "test": "vitest run",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "publish-packages": "pnpm publish"
  },
  "author": "Andy Jansson",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "catalog:typesNode2410",
    "eslint": "catalog:eslint10",
    "eslint-config-prettier": "^10.1.5",
    "jison-gho": "0.6.1-216",
    "postcss": "catalog:postcss85",
    "prettier": "catalog:prettier371",
    "typescript": "catalog:typescript59",
    "vitest": "catalog:vitest"
  },
  "dependencies": {
    "postcss-selector-parser": "^7.1.2",
    "postcss-value-parser": "^4.2.0"
  },
  "peerDependencies": {
    "postcss": "^8.4.38"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts"
  }
}

{
  "name": "weapp-tailwindcss",
  "version": "5.1.5",
  "description": "把 tailwindcss 原子化样式思想，带给小程序开发者们! bring tailwindcss to miniprogram developers!",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://tw.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/weapp-tailwindcss.git",
    "directory": "packages/weapp-tailwindcss"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/weapp-tailwindcss/issues"
  },
  "keywords": [
    "tailwindcss",
    "weapp",
    "wechat",
    "mini",
    "miniprogram",
    "mini app",
    "weapp-tw",
    "weapp-tailwindcss",
    "taro",
    "uni-app",
    "remax",
    "mpx",
    "jit",
    "mp",
    "android",
    "ios",
    "小程序",
    "vite",
    "postcss",
    "webpack",
    "webpack-plugin",
    "gulp",
    "gulp-plugin"
  ],
  "exports": {
    ".": {
      "style": "./index.css",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./escape": {
      "types": "./dist/escape.d.ts",
      "import": "./dist/escape.mjs",
      "require": "./dist/escape.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./gulp": {
      "types": "./dist/gulp.d.ts",
      "import": "./dist/gulp.mjs",
      "require": "./dist/gulp.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.mjs",
      "require": "./dist/generator.js"
    },
    "./postcss": {
      "types": "./dist/postcss.d.ts",
      "import": "./dist/postcss.mjs",
      "require": "./dist/postcss.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.mjs",
      "require": "./dist/defaults.js"
    },
    "./framework": {
      "types": "./dist/framework.d.ts",
      "import": "./dist/framework.mjs",
      "require": "./dist/framework.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.js"
    },
    "./reset": {
      "types": "./dist/reset.d.ts",
      "import": "./dist/reset.mjs",
      "require": "./dist/reset.js"
    },
    "./css-macro/postcss": {
      "types": "./dist/css-macro/postcss.d.ts",
      "import": "./dist/css-macro/postcss.mjs",
      "require": "./dist/css-macro/postcss.js"
    },
    "./css-macro": {
      "types": "./dist/css-macro.d.ts",
      "import": "./dist/css-macro.mjs",
      "require": "./dist/css-macro.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./postcss-html-transform": {
      "types": "./dist/postcss-html-transform.d.ts",
      "import": "./dist/postcss-html-transform.mjs",
      "require": "./dist/postcss-html-transform.js"
    },
    "./package.json": "./package.json",
    "./index.css": "./index.css",
    "./index": "./index.css",
    "./preflight.css": "./preflight.css",
    "./preflight": "./preflight.css",
    "./theme.css": "./theme.css",
    "./theme": "./theme.css",
    "./utilities.css": "./utilities.css",
    "./utilities": "./utilities.css",
    "./with-layer.css": "./with-layer.css",
    "./with-layer": "./with-layer.css",
    "./uni-app-x": "./uni-app-x.css",
    "./uni-app-x.css": "./uni-app-x.css",
    "./css": "./css/index.css",
    "./*": "./*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "index.css",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "bin": {
    "weapp-tailwindcss": "bin/weapp-tailwindcss.js",
    "weapp-tw": "bin/weapp-tailwindcss.js"
  },
  "files": [
    "bin",
    "css",
    "dist",
    "generator-placeholder.css",
    "index.css",
    "preflight.css",
    "theme.css",
    "uni-app-x.css",
    "utilities.css",
    "with-layer.css"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown && pnpm run build:types && pnpm --filter @weapp-tailwindcss/scripts ensure-escape-dts",
    "build:types": "tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --declarationDir dist --noEmit false && pnpm --filter @weapp-tailwindcss/scripts build:types",
    "build:tsc": "cross-env NODE_ENV=development tsc --build tsconfig.json",
    "build:cli": "cd plugins/cli && pnpm run build",
    "build:css": "pnpm --filter @weapp-tailwindcss/scripts build:css",
    "build:weapp-theme": "pnpm --filter @weapp-tailwindcss/scripts build:weapp-theme",
    "test": "vitest run",
    "test:dev": "vitest",
    "test:ui": "vitest --ui",
    "bench": "vitest bench --config ./vitest.config.ts",
    "bench:vite-perf": "pnpm --filter @weapp-tailwindcss/scripts bench:vite-perf",
    "bench:vite-perf:summary": "pnpm --filter @weapp-tailwindcss/scripts bench:vite-perf:summary",
    "bench:js-handlers": "pnpm --filter @weapp-tailwindcss/scripts bench:js-handlers",
    "bench:js-diff": "pnpm --filter @weapp-tailwindcss/scripts bench:js-diff",
    "tsd": "tsd",
    "clean": "pnpm --filter @weapp-tailwindcss/scripts clean:core",
    "get-decl": "pnpm --filter @weapp-tailwindcss/scripts get-decl",
    "ls:pack": "npm pack --dry-run",
    "colors": "pnpm --filter @weapp-tailwindcss/scripts colors",
    "release": "pnpm --filter @weapp-tailwindcss/scripts release",
    "lint": "eslint .",
    "lint:fix": "eslint ./src --fix",
    "bench:vite-dev-hmr": "pnpm --filter @weapp-tailwindcss/scripts bench:vite-dev-hmr",
    "watch-hmr:speed-report": "pnpm --filter @weapp-tailwindcss/scripts watch-hmr:speed-report",
    "test:watch-hmr": "pnpm --filter @weapp-tailwindcss/scripts test:watch-hmr"
  },
  "tsd": {
    "compilerOptions": {
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "paths": {
        "@/*": [
          "./src/*"
        ]
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@babel/parser": "~7.29.7",
    "@babel/traverse": "~7.29.7",
    "@babel/types": "~7.29.7",
    "@tailwindcss-mangle/engine": "catalog:tailwindcssMangleEngine",
    "@vue/compiler-dom": "catalog:vue3",
    "@weapp-core/escape": "~8.0.0",
    "@weapp-tailwindcss/logger": "workspace:*",
    "@weapp-tailwindcss/postcss": "workspace:*",
    "@weapp-tailwindcss/reset": "workspace:*",
    "@weapp-tailwindcss/shared": "workspace:*",
    "comment-json": "^5.0.0",
    "debug": "~4.4.3",
    "fast-glob": "^3.3.3",
    "local-pkg": "^1.2.1",
    "lru-cache": "11.5.1",
    "magic-string": "0.30.21",
    "micromatch": "^4.0.8",
    "semver": "~7.8.5",
    "tailwindcss-config": "workspace:*",
    "weapp-style-injector": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "htmlparser2": "12.0.0"
  }
}

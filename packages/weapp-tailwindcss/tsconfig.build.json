{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "removeComments": true,
    "sourceMap": false,
    "noCheck": true
  },
  "include": [
    "src/**/*",
    "types/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test/**/*",
    "e2e/**/*",
    "./*.d.ts"
  ]
}

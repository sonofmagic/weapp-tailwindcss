exports[`postcss plugin > dark mode variant 2 1`] = `
"@layer properties;
.tbody {
  .tr {
    border-bottom-style: var(--tw-border-style);
    border-bottom-width: 1px;
    border-color: var(--color-slate-100, oklch(96.8% 0.007 247.896));
    &:is(.dark *) {
      border-color: color-mix(in srgb, oklch(70.4% 0.04 256.788) 10%, transparent);
      @supports (color: color-mix(in lab, red, red)) {
        border-color: color-mix(in oklab, var(--color-slate-400, oklch(70.4% 0.04 256.788)) 10%, transparent);
      }
    }
    @media (prefers-color-scheme: dark) {
      &:not(.light *) {
        border-color: color-mix(in srgb, oklch(70.4% 0.04 256.788) 10%, transparent);
        @supports (color: color-mix(in lab, red, red)) {
          border-color: color-mix(in oklab, var(--color-slate-400, oklch(70.4% 0.04 256.788)) 10%, transparent);
        }
      }
    }
  }
}
@property --tw-border-style {
  syntax: "*";
  inherits: false;
  initial-value: solid;
}
@layer properties {
  @supports ((-webkit-hyphens: none) and (not (margin-trim: inline))) or ((-moz-orient: inline) and (not (color:rgb(from red r g b)))) {
    *, ::before, ::after, ::backdrop {
      --tw-border-style: solid;
    }
  }
}"
`;


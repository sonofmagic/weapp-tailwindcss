{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@weapp-tailwindcss/logger": [
        "../logger/src/index.ts"
      ],
      "@weapp-tailwindcss/postcss": [
        "../postcss/src/index.ts"
      ],
      "@weapp-tailwindcss/postcss/*": [
        "../postcss/src/*"
      ],
      "@weapp-tailwindcss/postcss/types": [
        "../postcss/src/types.ts"
      ],
      "@weapp-tailwindcss/reset": [
        "../reset/src/index.ts"
      ],
      "@weapp-tailwindcss/reset/*": [
        "../reset/src/*"
      ],
      "@weapp-tailwindcss/shared": [
        "../shared/src/index.ts"
      ],
      "@weapp-tailwindcss/shared/*": [
        "../shared/src/*"
      ],
      "#test/*": [
        "test/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "webpack",
      "node",
      "vitest/globals"
    ],
    "strictPropertyInitialization": false,
    "outDir": "dist",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test/types",
    "test/fixtures/**/*"
  ]
}

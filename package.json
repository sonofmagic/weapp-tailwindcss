{
  "name": "weapp-tailwindcss-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "把tailwindcss jit引擎，带给小程序开发者们! bring tailwindcss jit engine to miniprogram developers!",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://tw.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/weapp-tailwindcss.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/weapp-tailwindcss/issues"
  },
  "keywords": [
    "tailwindcss",
    "weapp",
    "wechat",
    "mini",
    "miniprogram",
    "mini app",
    "weapp-tw",
    "weapp-tailwindcss",
    "taro",
    "uni-app",
    "remax",
    "rax",
    "mpx",
    "jit",
    "mp",
    "android",
    "ios",
    "小程序",
    "vite",
    "postcss",
    "webpack",
    "webpack-plugin",
    "gulp",
    "gulp-plugin"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "cross-env WEAPP_TW_SKIP_INTERACTIVE_TARO_BUILD=1 WEAPP_TW_SKIP_INTERACTIVE_UNI_BUILD=1 turbo run build",
    "postbuild": "pnpm run e2e:update-snapshots",
    "clean:build-cache": "rimraf .turbo node_modules/.cache/turbo",
    "build:clean-cache": "pnpm run clean:build-cache",
    "build:nocache": "cross-env TURBO_FORCE=1 WEAPP_TW_SKIP_INTERACTIVE_TARO_BUILD=1 WEAPP_TW_SKIP_INTERACTIVE_UNI_BUILD=1 turbo run build",
    "build:docs": "turbo run build --filter=./website/",
    "deploy:docs:cf": "pnpm --filter @weapp-tailwindcss/website deploy:cf",
    "deploy:docs:cf:next": "pnpm --filter @weapp-tailwindcss/website deploy:cf:next",
    "build:apps": "echo \"apps workspace has no demo projects\"",
    "build:pkgs": "turbo run build --filter=./packages/* --filter=./packages-runtime/*",
    "build:demo": "cross-env WEAPP_TW_SKIP_INTERACTIVE_TARO_BUILD=1 WEAPP_TW_SKIP_INTERACTIVE_UNI_BUILD=1 turbo run build --filter=./demo/*",
    "build:analyze": "tsx scripts/check-build-size.ts",
    "test": "vitest run",
    "test:bench": "vitest bench",
    "bench": "pnpm --filter benchmark-* bench",
    "bench:ci": "node benchmark/version-compare/scripts/run-ci.mjs",
    "bench:framework:prepare": "node benchmark/framework-compare/scripts/prepare-minimal-projects.mjs",
    "bench:framework:matrix": "node benchmark/framework-compare/scripts/run-matrix.mjs",
    "bench:framework:sanitize": "node benchmark/framework-compare/scripts/sanitize-results.mjs",
    "bench:framework:report": "node benchmark/framework-compare/scripts/generate-report.mjs",
    "test:plugins": "vitest run --coverage.enabled --coverage.all=false --project=@weapp-tailwindcss/*",
    "test:typography": "vitest run --coverage.enabled --coverage.all=false --project=@weapp-tailwindcss/typography",
    "test:core": "vitest run --coverage.enabled --coverage.all=false --project=weapp-tailwindcss",
    "test:dev": "vitest",
    "test:ui": "vitest --ui",
    "tsd": "turbo run tsd",
    "tsd:runtime": "turbo run tsd --filter=./packages-runtime/*",
    "tsd:weapp-tailwindcss": "pnpm --filter weapp-tailwindcss tsd",
    "e2e": "pnpm e2e:static && pnpm e2e:hot-update",
    "e2e:dev": "vitest -c ./e2e/vitest.e2e.config.ts",
    "e2e:u": "pnpm e2e:static:u && pnpm e2e:hot-update",
    "e2e:static": "cross-env E2E_SKIP_OPEN_AUTOMATOR=1 vitest run -c ./e2e/vitest.e2e.config.ts",
    "e2e:static:dev": "vitest -c ./e2e/vitest.e2e.config.ts",
    "e2e:static:u": "cross-env E2E_SKIP_OPEN_AUTOMATOR=1 vitest run -u -c ./e2e/vitest.e2e.config.ts",
    "e2e:ci": "cross-env E2E_SKIP_OPEN_AUTOMATOR=1 vitest run --maxWorkers=1 -c ./e2e/vitest.e2e.config.ts && cross-env E2E_FRAMEWORK_SUPPORT=1 E2E_SKIP_OPEN_AUTOMATOR=1 vitest run --maxWorkers=1 -c ./e2e/vitest.e2e.config.ts e2e/framework-ci-support.test.ts",
    "e2e:ide": "cross-env E2E_IDE=1 E2E_IDE_BUILD=1 vitest run --bail=1 -c ./e2e/vitest.e2e.config.ts e2e/framework-ide-support.test.ts",
    "e2e:ide:build": "pnpm e2e:ide",
    "e2e:ide:skip-build": "cross-env E2E_IDE=1 E2E_IDE_BUILD=0 vitest run --bail=1 -c ./e2e/vitest.e2e.config.ts e2e/framework-ide-support.test.ts",
    "e2e:ide:case": "cross-env E2E_IDE=1 E2E_IDE_BUILD=1 E2E_IDE_PROBE_RETRIES=0 vitest run --bail=1 -c ./e2e/vitest.e2e.config.ts e2e/framework-ide-support.test.ts",
    "e2e:ide:case:skip-build": "cross-env E2E_IDE=1 E2E_IDE_BUILD=0 E2E_IDE_PROBE_RETRIES=0 vitest run --bail=1 -c ./e2e/vitest.e2e.config.ts e2e/framework-ide-support.test.ts",
    "e2e:preprocessor": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/preprocessor-source.test.ts",
    "e2e:apps-generator": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/apps-generator-mode-compare.test.ts",
    "e2e:apps-generator:u": "vitest run -u -c ./e2e/vitest.e2e.config.ts e2e/apps-generator-mode-compare.test.ts",
    "e2e:generator-parity": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/generator-tailwind-parity.test.ts",
    "e2e:hot-update": "node --import tsx ./e2e/run-hot-update.ts",
    "e2e:hot-update:dev": "pnpm e2e:hot-update",
    "e2e:hot-update:demo": "cross-env E2E_HOT_UPDATE_TARGET=demo pnpm e2e:hot-update",
    "e2e:hot-update:apps": "echo \"apps hot-update target has moved to demo\"",
    "e2e:watch": "vitest run -c ./e2e/vitest.e2e.watch.config.ts",
    "e2e:watch:full": "cross-env E2E_WATCH_SKIP_BUILD=0 pnpm e2e:watch",
    "e2e:watch:dev": "vitest -c ./e2e/vitest.e2e.watch.config.ts",
    "e2e:watch:demo": "cross-env E2E_WATCH_CASE=demo pnpm e2e:watch",
    "e2e:watch:apps": "echo \"apps watch target has moved to demo\"",
    "e2e:watch:taro": "cross-env E2E_WATCH_CASE=taro-webpack-react-tailwindcss-v3 pnpm e2e:watch",
    "e2e:watch:uni": "cross-env E2E_WATCH_CASE=uni-app-vite-tailwindcss-v3 pnpm e2e:watch",
    "e2e:watch:mpx": "cross-env E2E_WATCH_CASE=mpx-tailwindcss-v3 pnpm e2e:watch",
    "e2e:watch:weapp-vite": "cross-env E2E_WATCH_CASE=weapp-vite-tailwindcss-v3 pnpm e2e:watch",
    "e2e:watch:speed-report": "node .github/scripts/e2e-watch-report.cjs speed-report",
    "e2e:update-snapshots": "node scripts/e2e-update-snapshots-runner.mjs",
    "demo:build": "pnpm run build:demo",
    "demo:web:compare": "node demo/web/scripts/compare-dev-weapp.mjs",
    "demo:install": "tsx scripts/demo/install.ts",
    "demo:install:beta": "tsx scripts/demo/install.ts --beta",
    "demo:install:alpha": "tsx scripts/demo/install.ts --alpha",
    "sync": "cnpm sync weapp-tailwindcss weapp-tw @weapp-tailwindcss/cli @weapp-tailwindcss/reset @weapp-tailwindcss/typography",
    "sync:all": "turbo run sync",
    "templates:sync": "tsx scripts/sync-templates.ts && pnpm templates:update-deps",
    "templates:push": "pnpm templates:update-deps && tsx scripts/push-templates.ts",
    "templates:update-deps": "tsx scripts/update-template-deps.ts",
    "generate:readme": "tsx scripts/readme/write.ts",
    "docs:api": "tsx website/scripts/generate-api-docs.ts",
    "format": "prettier --check \"src/**/*.{ts,js}\" -w",
    "format:test": "prettier --check \"test/**/*.test.{ts,js}\" -w",
    "ls:pack": "npm pack --dry-run",
    "prepare": "husky",
    "css-build": "css2plugin build css-plugin.css css-plugin-scss.scss --cwd test/fixtures/css",
    "css-build-out": "css2plugin build css-plugin.css css-plugin-scss.scss --cwd test/fixtures/css --out tw-plugins",
    "-------": "-----------",
    "release": "changeset",
    "pr": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "cv": "changeset version ",
    "--------": "----------------",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:view": "npx @eslint/config-inspector",
    "stylelint": "stylelint \"packages-runtime/**/*.{css,scss}\" --allow-empty-input",
    "typecheck": "pnpm --filter tailwindcss-config exec tsc -p tsconfig.json --pretty false && pnpm --filter @weapp-tailwindcss/test-helper exec tsc -p tsconfig.json --pretty false && pnpm --filter weapp-tailwindcss exec tsc -p tsconfig.build.json --noEmit --noCheck false --pretty false",
    "publish-packages": "node scripts/publish-packages.mjs",
    "dev:apps": "echo \"apps workspace has no demo projects\"",
    "run:watch": "tsx scripts/watcher",
    "showcase:update": "tsx scripts/update-showcase.ts",
    "set-private": "tsx scripts/setPrivate.ts",
    "repo:init": "repo init",
    "repo:doctor": "repo doctor",
    "repo:new": "repo new",
    "repo:check": "repo check",
    "repo:upgrade": "repo upgrade",
    "script:init": "pnpm run repo:init",
    "script:sync": "repo ws upgrade",
    "script:clean": "repo ws clean",
    "commitlint": "commitlint --edit",
    "up:pkg:latest": "node scripts/pnpm-smart-proxy.mjs up -rLi \"!@dcloudio/*\"",
    "up:pkg": "node scripts/pnpm-smart-proxy.mjs up -ri \"!@dcloudio/*\"",
    "up:uniapp": "pnpx @dcloudio/uvm@latest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
